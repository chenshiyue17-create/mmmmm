COMPOSE_PROJECT_NAME=freqtrade-deploy
FREQTRADE_IMAGE=freqtradeorg/freqtrade:stable
FREQTRADE_UI_PORT=8080
FREQTRADE_BACKEND_PORT=8080
FREQTRADE_RUN_MODE=trade
READONLY_PROXY_ENABLED=0
FREQTRADE_START_PATH=/analysis.html
AUTO_LOGIN_ENABLED=1
FT_BOT_NAME=freqtrade
FT_API_URL=http://localhost:8080
TZ=Asia/Shanghai

# Server mode keeps the UI/API bound to 127.0.0.1 through docker-compose.yml.
# Open it from your computer with an SSH tunnel:
# ssh -L 8080:127.0.0.1:8080 root@YOUR_SERVER_IP

FT_API_USERNAME=freqtrade
FT_API_PASSWORD=replace-with-long-random-password
FT_JWT_SECRET_KEY=replace-with-long-random-jwt-secret-at-least-32-chars
FT_WS_TOKEN=replace-with-long-random-websocket-token

# Exchange APIs only. Keep withdrawal permission disabled on the exchange side.
BINANCE_KEY=
BINANCE_SECRET=
OKX_KEY=
OKX_SECRET=
OKX_PASSWORD=

# Start on OKX demo/sandbox. Change only after a separate live-trading review.
OKX_SANDBOX_MODE=1

# Server execution node: trade independently. Local machine may research and sync
# bounded strategy overlays, but server trading must not depend on local uptime.
ML_SIGNAL_FILTER_ENABLED=0
GEMINI_OPTIMIZER_ENABLED=0
GEMINI_AUTOMATION_ENABLED=0
GEMINI_AUTOMATION_MIN_CONFIDENCE=0.55
GEMINI_OPTIMIZER_INTERVAL_SECONDS=900

# 0 means the guardian runs until scripts/stop-dev.sh or systemctl stop.
GUARDIAN_RUNTIME_HOURS=0
GUARDIAN_FAILURE_THRESHOLD=3
GUARDIAN_INTERVAL_SECONDS=30
