COMPOSE_PROJECT_NAME=freqtrade-deploy
FREQTRADE_IMAGE=freqtradeorg/freqtrade:stable
FREQTRADE_UI_PORT=8080
FREQTRADE_BACKEND_PORT=8080
FREQTRADE_RUN_MODE=trade
READONLY_PROXY_ENABLED=0
FREQTRADE_START_PATH=/dashboard
AUTO_LOGIN_ENABLED=1
FT_BOT_NAME=freqtrade
FT_API_URL=http://localhost:8080
TZ=Asia/Shanghai

# Copy this file to .env before running scripts.
# Only exchange API credentials belong here. Do not add third-party API keys.
# Never commit real exchange keys.
FT_API_USERNAME=freqtrade
FT_API_PASSWORD=change-this-password
FT_JWT_SECRET_KEY=change-this-jwt-secret
FT_WS_TOKEN=change-this-ws-token

# Exchange APIs only. Keep withdrawal permission disabled on the exchange side.
BINANCE_KEY=
BINANCE_SECRET=
OKX_KEY=
OKX_SECRET=
OKX_PASSWORD=
OKX_SANDBOX_MODE=0

# Optional ML strategy filter. Disabled by default; when enabled, strategy entries
# are allowed only if output/ml_models/latest_signals.json passes deployment_gate.
ML_SIGNAL_FILTER_ENABLED=0

# Gemini CLI continuous optimizer. It only auto-writes
# user_data/datugou_flow.autopilot.json after schema and bounds validation.
GEMINI_AUTOMATION_ENABLED=1
GEMINI_AUTOMATION_MIN_CONFIDENCE=0.55
GEMINI_OPTIMIZER_INTERVAL_SECONDS=900
